KEYCRM_API_KEY=your-api-key-here
PORT=3000

# Basic Auth for Vercel deploy — MANAGER account (no GEO tab)
AUTH_USER=surf
AUTH_PASS=change-me

# ADMIN account — logging in with these (instead of the manager ones) reveals the GEO tab
ADMIN_USER=admin
ADMIN_PASS=change-me

# Optional: secret used to sign the surf_auth role cookie (defaults to AUTH_PASS).
# Set the SAME value for all envs; changing it logs everyone out.
# AUTH_SECRET=some-long-random-string
